# ─────────────────────────────────────────────
#  Portfolio Backend — Environment Variables
#  Copy this file: cp .env.example .env
# ─────────────────────────────────────────────

# ── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development        # set to "production" on Render

# ── MongoDB Atlas ────────────────────────────
# Get this from: mongodb.com/atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://youruser:yourpassword@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_64_char_random_string
JWT_EXPIRES_IN=7d

# ── Admin Account ────────────────────────────
# Auto-created on first server startup (only if no admin exists)
ADMIN_EMAIL=admin@yourportfolio.com
ADMIN_PASSWORD=ChangeMe@123

# ── CORS ─────────────────────────────────────
# Set to your Vercel frontend URL after deploying
# Example: https://my-portfolio.vercel.app
FRONTEND_URL=https://your-portfolio.vercel.app
